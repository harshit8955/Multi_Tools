{
  "rules": {
    "config": {
      "toolsEnabled": {
        ".read": true,
        ".write": "auth != null"
      },
      "adminCreds": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
